generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum MarketStatus {
  OPEN
  CLOSED
  PENDING_RESOLUTION
  RESOLVED
}

enum PositionSide {
  YES
  NO
}

enum PositionStatus {
  PENDING
  CONFIRMED
}

enum PayoutConfirmationStatus {
  PENDING_CREATOR
  PENDING_RECIPIENT
  DISPUTED
  CONFIRMED
}

model User {
  id                        String                         @id @default(cuid())
  auth0UserId               String                         @unique
  email                     String                         @unique
  displayName               String
  avatarUrl                 String?
  venmoHandle               String?
  hasCompletedTutorial      Boolean                        @default(false)
  balance                   Int                            @default(0)
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  memberships               GroupMembership[]
  createdMarkets            Market[]                       @relation("CreatedMarkets")
  targetMarkets             Market[]                       @relation("TargetMarkets")
  proposedResolutionMarkets Market[]                       @relation("ProposedResolutionMarkets")
  positions                 Position[]
  payouts                   MarketPayoutConfirmation[]
  resolutionConfirmations   MarketResolutionConfirmation[]
}

model FamilyGroup {
  id          String            @id @default(cuid())
  name        String
  joinCode    String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships GroupMembership[]
  markets     Market[]
}

model GroupMembership {
  id        String      @id @default(cuid())
  userId    String
  groupId   String
  role      GroupRole   @default(MEMBER)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Market {
  id                         String                         @id @default(cuid())
  groupId                    String
  createdByUserId            String
  targetUserId               String?
  question                   String
  description                String?
  closesAt                   DateTime
  resolvesAt                 DateTime?
  status                     MarketStatus                   @default(OPEN)
  resolution                 Boolean?
  resolutionProposedByUserId String?
  resolutionProposedAt       DateTime?
  liquidityPool              Int                            @default(100)
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  payoutsFinalizedAt         DateTime?
  group                      FamilyGroup                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy                  User                           @relation("CreatedMarkets", fields: [createdByUserId], references: [id], onDelete: Cascade)
  targetUser                 User?                          @relation("TargetMarkets", fields: [targetUserId], references: [id], onDelete: Cascade)
  resolutionProposedBy       User?                          @relation("ProposedResolutionMarkets", fields: [resolutionProposedByUserId], references: [id], onDelete: SetNull)
  positions                  Position[]
  payoutConfirmations        MarketPayoutConfirmation[]
  resolutionConfirmations    MarketResolutionConfirmation[]
}

model Position {
  id          String         @id @default(cuid())
  marketId    String
  userId      String
  side        PositionSide
  status      PositionStatus @default(PENDING)
  amount      Int
  createdAt   DateTime       @default(now())
  confirmedAt DateTime?
  market      Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([userId])
}

model MarketPayoutConfirmation {
  id                   String                   @id @default(cuid())
  marketId             String
  recipientUserId      String
  amount               Int
  status               PayoutConfirmationStatus @default(PENDING_CREATOR)
  creatorMarkedAt      DateTime?
  recipientRespondedAt DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  market               Market                   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  recipient            User                     @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([marketId, recipientUserId])
  @@index([marketId])
  @@index([recipientUserId])
}

model MarketResolutionConfirmation {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([marketId, userId])
  @@index([marketId])
  @@index([userId])
}
